# Variáveis de Ambiente - SmartLegis Label

# URL da API (usado como fallback quando não consegue detectar tenant)
VITE_API_URL=https://jc.smartlegis.net.br
VITE_API_BASE_URL=https://jc.smartlegis.net.br/api

# Ambiente (development, staging, production)
VITE_APP_ENV=development

# Habilitar logs de debug
VITE_DEBUG=true

# URL do bucket S3 para assets
VITE_S3_HOST=https://smartlegis-production.s3.amazonaws.com
