<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 120 80" fill="none">
  <!-- Fundo do logo MDB -->
  <rect width="120" height="80" fill="white"/>
  
  <!-- Texto MDB estilizado -->
  <text x="60" y="50" font-family="Arial Black, sans-serif" font-size="36" font-weight="900" fill="#1E3A8A" text-anchor="middle">
    MDB
  </text>
  
  <!-- Estrela acima -->
  <polygon points="60,10 63,18 72,18 65,23 67,32 60,27 53,32 55,23 48,18 57,18" fill="#DC2626"/>
  
  <!-- Base verde -->
  <rect x="0" y="70" width="120" height="10" fill="#16A34A"/>
  
  <!-- Barra amarela -->
  <rect x="0" y="60" width="120" height="10" fill="#FBBF24"/>
</svg>
